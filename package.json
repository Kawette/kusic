{
  "name": "kusic",
  "version": "1.0.0",
  "description": "Agrégateur de playlists Spotify & SoundCloud",
  "type": "module",
  "main": "dist/main/main.js",
  "scripts": {
    "build": "node build.js",
    "watch": "tsc --watch",
    "start": "npm run build && electron .",
    "dev": "npm run build && electron . --dev",
    "dist": "npm run build && electron-builder --win"
  },
  "build": {
    "appId": "dev.kusic.app",
    "productName": "Kusic",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    }
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "electron": "^28.0.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "electron-store": "^8.1.0",
    "extract-zip": "^2.0.1",
    "music-metadata": "^11.12.3",
    "node-taglib-sharp": "^6.0.1",
    "yaml": "^2.8.2"
  }
}
